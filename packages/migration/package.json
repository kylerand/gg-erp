{
  "name": "@gg-erp/migration",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./loaders/*": "./src/loaders/*"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "fetch-shopmonkey": "tsx src/cli/fetch-shopmonkey.ts",
    "sanitize-shopmonkey": "tsx src/cli/sanitize-shopmonkey.ts",
    "load-shopmonkey": "tsx --env-file=../../.env src/cli/load-shopmonkey.ts",
    "migrate": "tsx --env-file=../../.env src/cli/run-wave.ts"
  },
  "dependencies": {
    "@gg-erp/db": "*",
    "@gg-erp/domain": "*"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  }
}
