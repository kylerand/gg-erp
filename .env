# Local development environment
# For Docker postgres: postgresql://postgres:postgres@localhost:5432/gg_erp
# For Homebrew postgres: postgresql://kylerand@localhost:5432/gg_erp
NODE_ENV=development

# API
API_PORT=3001
API_JWT_SECRET=local-dev-secret
API_COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_example
API_COGNITO_AUDIENCE=erp-web-client
API_COGNITO_USER_POOL_ID=us-east-2_example
API_COGNITO_REGION=us-east-2
API_COGNITO_TOKEN_USE=access
API_COGNITO_CLOCK_SKEW_SECONDS=30

# Web
WEB_API_BASE_URL=http://localhost:3001
WEB_TELEMETRY_ENABLED=true

# Workers
WORKER_NAME=gg-erp-workers
WORKER_LOG_LEVEL=info
WORKER_MAX_RETRIES=3
WORKER_POLL_INTERVAL_MS=5000

# DB — Homebrew postgres (no password)
DB_DATABASE_URL=postgresql://kylerand@localhost:5432/gg_erp

# AWS (local dev stubs)
AWS_REGION=us-east-2
