# Shared
NODE_ENV=development

# API
API_PORT=3001
API_JWT_SECRET=change-me
API_COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_example
API_COGNITO_AUDIENCE=erp-web-client
API_COGNITO_USER_POOL_ID=us-east-2_example
API_COGNITO_REGION=us-east-2
API_COGNITO_TOKEN_USE=access
API_COGNITO_CLOCK_SKEW_SECONDS=30

# Web
WEB_API_BASE_URL=http://localhost:3001
WEB_TELEMETRY_ENABLED=true

# Workers
WORKER_NAME=gg-erp-workers
WORKER_LOG_LEVEL=info
WORKER_MAX_RETRIES=3
WORKER_POLL_INTERVAL_MS=5000

# DB
# Docker postgres:   postgresql://postgres:postgres@localhost:5432/gg_erp
# Homebrew postgres: postgresql://<your-mac-username>@localhost:5432/gg_erp
DB_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/gg_erp

# AWS
AWS_REGION=us-east-2

# QuickBooks Online Integration
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3001/accounting/oauth/callback
QB_REALM_ID=
QB_ACCESS_TOKEN=
QB_REFRESH_TOKEN=
QB_TOKEN_EXPIRES_AT=
QB_WEBHOOK_VERIFIER_TOKEN=
FRONTEND_URL=http://localhost:3000
