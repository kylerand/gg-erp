generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DB_DATABASE_URL")
  schemas  = ["planning", "audit", "obs", "migration", "identity", "hr", "inventory", "work_orders", "integrations", "sop_ojt", "customers", "tickets", "accounting"]
}

enum WorkOrderStatus {
  PLANNED
  RELEASED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED

  @@schema("planning")
}

enum CartVehicleStatus {
  REGISTERED
  IN_BUILD
  QUALITY_HOLD
  COMPLETED
  RETIRED

  @@schema("planning")
}

model CartVehicle {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vin          String            @unique @map("vin")
  serialNumber String            @unique @map("serial_number")
  modelCode    String            @map("model_code")
  modelYear    Int               @map("model_year")
  customerId   String            @map("customer_id") @db.Uuid
  state        CartVehicleStatus @default(REGISTERED)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([customerId, state], map: "cart_vehicles_customer_state_idx")
  @@map("cart_vehicles")
  @@schema("planning")
}

model VinSequence {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("vin_sequences")
  @@schema("planning")
}

model WorkOrder {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderNumber       String          @unique @map("work_order_number")
  vehicleId             String          @map("vehicle_id")
  buildConfigurationId  String          @map("build_configuration_id")
  bomId                 String          @map("bom_id")
  state                 WorkOrderStatus @default(PLANNED)
  scheduledStartAt      DateTime?       @map("scheduled_start_at") @db.Timestamptz(6)
  scheduledEndAt        DateTime?       @map("scheduled_end_at") @db.Timestamptz(6)
  completedAt           DateTime?       @map("completed_at") @db.Timestamptz(6)
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdByUserId       String?         @map("created_by_user_id") @db.Uuid
  updatedByUserId       String?         @map("updated_by_user_id") @db.Uuid
  lastCorrelationId     String?         @map("last_correlation_id")
  lastRequestId         String?         @map("last_request_id")
  activeReworkLoopCount Int             @default(0) @map("active_rework_loop_count")
  qcGateState           String          @default("PENDING") @map("qc_gate_state")

  @@index([state], map: "work_orders_state_idx")
  @@index([vehicleId], map: "work_orders_vehicle_idx")
  @@index([createdAt], map: "work_orders_created_idx")
  @@map("work_orders")
  @@schema("planning")
}

enum PlanningScenarioStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@schema("planning")
}

enum PlanPublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("planning")
}

model PlanningScenario {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenarioName   String                 @unique @map("scenario_name")
  scenarioStatus PlanningScenarioStatus @default(ACTIVE) @map("scenario_status")
  description    String?
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  version        Int                    @default(0)

  constraints  PlanningConstraint[]
  publications PlanPublication[]

  @@map("planning_scenarios")
  @@schema("planning")
}

model PlanningConstraint {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenarioId      String   @map("scenario_id") @db.Uuid
  constraintKey   String   @map("constraint_key")
  constraintValue Json     @default("{}") @map("constraint_value") @db.JsonB
  isEnabled       Boolean  @default(true) @map("is_enabled")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  version         Int      @default(0)

  scenario PlanningScenario @relation(fields: [scenarioId], references: [id])

  @@unique([scenarioId, constraintKey], map: "planning_constraints_scenario_id_constraint_key_key")
  @@map("planning_constraints")
  @@schema("planning")
}

model PlanPublication {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicationKey    String                @unique @map("publication_key")
  scenarioId        String?               @map("scenario_id") @db.Uuid
  publicationStatus PlanPublicationStatus @default(DRAFT) @map("publication_status")
  effectiveFrom     DateTime?             @map("effective_from") @db.Timestamptz(6)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  version           Int                   @default(0)

  scenario PlanningScenario? @relation(fields: [scenarioId], references: [id])

  @@map("plan_publications")
  @@schema("planning")
}

model AuditEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId       String?  @map("actor_id") @db.Uuid
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  correlationId String   @map("correlation_id")
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId], map: "audit_events_entity_idx")
  @@index([correlationId], map: "audit_events_correlation_idx")
  @@map("audit_events")
  @@schema("audit")
}

model EventOutbox {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventName     String    @map("event_name")
  correlationId String    @map("correlation_id")
  payload       Json
  state         String    @default("PENDING")
  attemptCount  Int       @default(0) @map("attempt_count")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  publishedAt   DateTime? @map("published_at") @db.Timestamptz(6)

  @@index([state, createdAt], map: "event_outbox_state_created_idx")
  @@map("event_outbox")
  @@schema("obs")
}

// ============================================================
// ShopMonkey Migration Staging Schema
// ============================================================

enum ImportBatchStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED

  @@schema("migration")
}

enum ImportEntityType {
  ORGANIZATION
  EMPLOYEE
  PART
  INVENTORY_LOT
  CUSTOMER
  ASSET
  WORK_ORDER
  WORK_ORDER_OPERATION
  WORK_ORDER_PART
  VENDOR

  @@schema("migration")
}

enum ValidationStatus {
  VALID
  WARN
  INVALID

  @@schema("migration")
}

model ImportBatch {
  id          String            @id @default(cuid())
  status      ImportBatchStatus @default(QUEUED)
  wave        String
  sourceFile  String
  recordCount Int               @default(0)
  errorCount  Int               @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  rawRecords            RawRecord[]
  reconciliationResults ReconciliationResult[]
  migrationErrors       MigrationError[]

  @@schema("migration")
}

model RawRecord {
  id         String           @id @default(cuid())
  batchId    String
  entityType ImportEntityType
  sourceId   String
  rawJson    Json
  checksum   String
  createdAt  DateTime         @default(now())

  batch       ImportBatch      @relation(fields: [batchId], references: [id])
  stageRecord StageRecord?
  errors      MigrationError[]

  @@unique([batchId, sourceId, entityType])
  @@index([batchId])
  @@index([entityType, sourceId])
  @@schema("migration")
}

model StageRecord {
  id               String           @id @default(cuid())
  rawRecordId      String           @unique
  entityType       ImportEntityType
  stagingJson      Json
  validationStatus ValidationStatus @default(VALID)
  warnings         String[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  rawRecord RawRecord @relation(fields: [rawRecordId], references: [id])

  @@index([entityType])
  @@index([validationStatus])
  @@schema("migration")
}

model DuplicateCandidate {
  id           String           @id @default(cuid())
  entityType   ImportEntityType
  candidateAId String
  candidateBId String
  confidence   Float
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())

  @@index([entityType])
  @@index([resolution])
  @@schema("migration")
}

model ReconciliationResult {
  id            String           @id @default(cuid())
  batchId       String
  entityType    ImportEntityType
  sourceCount   Int
  importedCount Int
  mismatches    Json[]
  createdAt     DateTime         @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@schema("migration")
}

model MigrationError {
  id           String    @id @default(cuid())
  batchId      String
  rawRecordId  String?
  phase        String
  errorCode    String
  errorMessage String
  retryable    Boolean   @default(false)
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  batch     ImportBatch @relation(fields: [batchId], references: [id])
  rawRecord RawRecord?  @relation(fields: [rawRecordId], references: [id])

  @@index([batchId])
  @@index([retryable])
  @@schema("migration")
}

// ============================================================
// identity schema
// ============================================================

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED

  @@schema("identity")
}

model User {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cognitoSubject String     @unique @map("cognito_subject")
  email          String
  displayName    String     @map("display_name")
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz(6)
  version        Int        @default(0)

  userRoles              UserRole[]
  employee               Employee?
  grantedRolePermissions RolePermission[] @relation("RolePermissionGrantedByUser")

  @@index([status])
  @@map("users")
  @@schema("identity")
}

model Role {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCode    String    @map("role_code")
  roleName    String    @map("role_name")
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  version     Int       @default(0)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([roleCode])
  @@map("roles")
  @@schema("identity")
}

model Permission {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  permissionCode String    @map("permission_code")
  permissionName String    @map("permission_name")
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  version        Int       @default(0)

  rolePermissions RolePermission[]

  @@index([permissionCode])
  @@map("permissions")
  @@schema("identity")
}

model RolePermission {
  roleId          String   @map("role_id") @db.Uuid
  permissionId    String   @map("permission_id") @db.Uuid
  grantedByUserId String?  @map("granted_by_user_id") @db.Uuid
  correlationId   String   @map("correlation_id")
  requestId       String?  @map("request_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role          Role       @relation(fields: [roleId], references: [id])
  permission    Permission @relation(fields: [permissionId], references: [id])
  grantedByUser User?      @relation("RolePermissionGrantedByUser", fields: [grantedByUserId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
  @@schema("identity")
}

enum UserRoleAssignmentStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@schema("identity")
}

model UserRole {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String                   @map("user_id") @db.Uuid
  roleId           String                   @map("role_id") @db.Uuid
  assignmentStatus UserRoleAssignmentStatus @default(ACTIVE) @map("assignment_status")
  effectiveFrom    DateTime                 @default(now()) @map("effective_from") @db.Timestamptz(6)
  effectiveTo      DateTime?                @map("effective_to") @db.Timestamptz(6)
  correlationId    String                   @map("correlation_id")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  version          Int                      @default(0)

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@index([roleId, assignmentStatus])
  @@map("user_roles")
  @@schema("identity")
}

// ============================================================
// hr schema
// ============================================================

enum EmploymentState {
  ACTIVE
  ON_LEAVE
  TERMINATED

  @@schema("hr")
}

model Employee {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String?         @unique @map("user_id") @db.Uuid
  employeeNumber       String          @map("employee_number")
  firstName            String          @map("first_name")
  lastName             String          @map("last_name")
  employmentState      EmploymentState @default(ACTIVE) @map("employment_state")
  hireDate             DateTime        @map("hire_date") @db.Date
  terminationDate      DateTime?       @map("termination_date") @db.Date
  supervisorEmployeeId String?         @map("supervisor_employee_id") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?       @map("deleted_at") @db.Timestamptz(6)
  version              Int             @default(0)

  user                 User?                   @relation(fields: [userId], references: [id])
  supervisor           Employee?               @relation("EmployeeSupervisor", fields: [supervisorEmployeeId], references: [id])
  subordinates         Employee[]              @relation("EmployeeSupervisor")
  skills               EmployeeSkill[]
  certifications       EmployeeCertification[]
  workOrderAssignments WoAssignment[]
  trainingAssignments  TrainingAssignment[]

  @@index([employmentState])
  @@map("employees")
  @@schema("hr")
}

model EmployeeSkill {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId       String    @map("employee_id") @db.Uuid
  skillCode        String    @map("skill_code")
  proficiencyLevel Int       @map("proficiency_level")
  isCertified      Boolean   @default(false) @map("is_certified")
  lastValidatedAt  DateTime? @map("last_validated_at") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  version          Int       @default(0)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_skills")
  @@schema("hr")
}

enum CertificationStatus {
  ACTIVE
  EXPIRED
  REVOKED

  @@schema("hr")
}

model EmployeeCertification {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String              @map("employee_id") @db.Uuid
  certificationCode   String              @map("certification_code")
  certificationName   String              @map("certification_name")
  certificationStatus CertificationStatus @default(ACTIVE) @map("certification_status")
  issuedAt            DateTime?           @map("issued_at") @db.Date
  expiresAt           DateTime?           @map("expires_at") @db.Date
  issuer              String?
  evidenceUri         String?             @map("evidence_uri")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?           @map("deleted_at") @db.Timestamptz(6)
  version             Int                 @default(0)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_certifications")
  @@schema("hr")
}

// ============================================================
// inventory schema
// ============================================================

enum UomCategory {
  COUNT
  LENGTH
  WEIGHT
  VOLUME
  TIME
  OTHER

  @@schema("inventory")
}

model UnitOfMeasure {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uomCode      String      @map("uom_code")
  uomName      String      @map("uom_name")
  uomCategory  UomCategory @default(COUNT) @map("uom_category")
  decimalScale Int         @default(3) @map("decimal_scale")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)
  version      Int         @default(0)

  purchaseOrderLines PurchaseOrderLine[]

  @@map("units_of_measure")
  @@schema("inventory")
}

enum PartState {
  ACTIVE
  INACTIVE
  DISCONTINUED

  @@schema("inventory")
}

model Part {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku           String
  name          String
  description   String?
  unitOfMeasure String    @default("EA") @map("unit_of_measure")
  partState     PartState @default(ACTIVE) @map("part_state")
  reorderPoint  Decimal   @default(0) @map("reorder_point") @db.Decimal(14, 3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  version       Int       @default(0)

  stockLots          StockLot[]
  workOrderParts     WoPartLine[]
  purchaseOrderLines PurchaseOrderLine[]

  @@index([partState])
  @@map("parts")
  @@schema("inventory")
}

enum StockLocationType {
  WAREHOUSE
  BAY
  VAN
  STAGING

  @@schema("inventory")
}

model StockLocation {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationCode     String            @map("location_code")
  locationName     String            @map("location_name")
  locationType     StockLocationType @map("location_type")
  parentLocationId String?           @map("parent_location_id") @db.Uuid
  isPickable       Boolean           @default(true) @map("is_pickable")
  timezoneName     String            @default("UTC") @map("timezone_name")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  version          Int               @default(0)

  parent     StockLocation?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  children   StockLocation[] @relation("LocationHierarchy")
  stockLots  StockLot[]
  workOrders WoOrder[]

  @@map("stock_locations")
  @@schema("inventory")
}

enum LotState {
  AVAILABLE
  QUARANTINED
  CONSUMED
  CLOSED

  @@schema("inventory")
}

model StockLot {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partId          String    @map("part_id") @db.Uuid
  stockLocationId String    @map("stock_location_id") @db.Uuid
  lotNumber       String?   @map("lot_number")
  serialNumber    String?   @map("serial_number")
  lotState        LotState  @default(AVAILABLE) @map("lot_state")
  manufacturredAt DateTime? @map("manufactured_at") @db.Date
  receivedAt      DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  expiresAt       DateTime? @map("expires_at") @db.Date
  metadata        Json      @default("{}") @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  version         Int       @default(0)

  part          Part          @relation(fields: [partId], references: [id])
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@index([partId, lotState])
  @@map("stock_lots")
  @@schema("inventory")
}

enum VendorState {
  ACTIVE
  ON_HOLD
  INACTIVE

  @@schema("inventory")
}

model Vendor {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorCode   String      @map("vendor_code")
  vendorName   String      @map("vendor_name")
  vendorState  VendorState @default(ACTIVE) @map("vendor_state")
  email        String?
  phone        String?
  leadTimeDays Int?        @map("lead_time_days")
  paymentTerms String?     @map("payment_terms")
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)
  version      Int         @default(0)

  purchaseOrders PurchaseOrder[]

  @@index([vendorState])
  @@map("vendors")
  @@schema("inventory")
}

enum PurchaseOrderState {
  DRAFT
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED

  @@schema("inventory")
}

model PurchaseOrder {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poNumber           String             @map("po_number")
  vendorId           String             @map("vendor_id") @db.Uuid
  purchaseOrderState PurchaseOrderState @default(DRAFT) @map("purchase_order_state")
  orderedAt          DateTime           @default(now()) @map("ordered_at") @db.Timestamptz(6)
  expectedAt         DateTime?          @map("expected_at") @db.Timestamptz(6)
  sentAt             DateTime?          @map("sent_at") @db.Timestamptz(6)
  closedAt           DateTime?          @map("closed_at") @db.Timestamptz(6)
  notes              String?
  correlationId      String             @map("correlation_id")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  version            Int                @default(0)

  vendor Vendor              @relation(fields: [vendorId], references: [id])
  lines  PurchaseOrderLine[]

  @@index([vendorId, purchaseOrderState])
  @@map("purchase_orders")
  @@schema("inventory")
}

model PurchaseOrderLine {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId  String    @map("purchase_order_id") @db.Uuid
  lineNumber       Int       @map("line_number")
  partId           String    @map("part_id") @db.Uuid
  orderedQuantity  Decimal   @map("ordered_quantity") @db.Decimal(14, 3)
  receivedQuantity Decimal   @default(0) @map("received_quantity") @db.Decimal(14, 3)
  rejectedQuantity Decimal   @default(0) @map("rejected_quantity") @db.Decimal(14, 3)
  unitOfMeasureId  String    @map("unit_of_measure_id") @db.Uuid
  unitCost         Decimal   @map("unit_cost") @db.Decimal(14, 4)
  promisedAt       DateTime? @map("promised_at") @db.Timestamptz(6)
  lineState        String    @default("OPEN") @map("line_state")
  correlationId    String    @map("correlation_id")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  version          Int       @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  part          Part          @relation(fields: [partId], references: [id])
  unitOfMeasure UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])

  @@index([partId, lineState])
  @@map("purchase_order_lines")
  @@schema("inventory")
}

// ============================================================
// work_orders schema (execution layer)
// ============================================================

enum WoStatus {
  DRAFT
  READY
  SCHEDULED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED

  @@schema("work_orders")
}

model WoOrder {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderNumber   String    @map("work_order_number")
  customerReference String?   @map("customer_reference")
  assetReference    String?   @map("asset_reference")
  title             String
  description       String?
  status            WoStatus  @default(DRAFT)
  priority          Int       @default(3)
  stockLocationId   String?   @map("stock_location_id") @db.Uuid
  openedAt          DateTime  @default(now()) @map("opened_at") @db.Timestamptz(6)
  dueAt             DateTime? @map("due_at") @db.Timestamptz(6)
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(6)
  createdByUserId   String    @map("created_by_user_id") @db.Uuid
  updatedByUserId   String?   @map("updated_by_user_id") @db.Uuid
  correlationId     String    @map("correlation_id")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  version           Int       @default(0)

  stockLocation StockLocation?    @relation(fields: [stockLocationId], references: [id])
  operations    WoOperation[]
  parts         WoPartLine[]
  statusHistory WoStatusHistory[]
  qcGates       WorkOrderQcGate[]

  @@unique([workOrderNumber])
  @@index([status, dueAt])
  @@map("work_orders")
  @@schema("work_orders")
}

enum WoOperationStatus {
  PENDING
  READY
  IN_PROGRESS
  BLOCKED
  DONE
  SKIPPED
  CANCELLED

  @@schema("work_orders")
}

model WoOperation {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId       String            @map("work_order_id") @db.Uuid
  operationCode     String            @map("operation_code")
  sequenceNo        Int               @map("sequence_no")
  operationName     String            @map("operation_name")
  requiredSkillCode String?           @map("required_skill_code")
  estimatedMinutes  Int               @map("estimated_minutes")
  operationStatus   WoOperationStatus @default(PENDING) @map("operation_status")
  plannedStartAt    DateTime?         @map("planned_start_at") @db.Timestamptz(6)
  plannedEndAt      DateTime?         @map("planned_end_at") @db.Timestamptz(6)
  actualStartAt     DateTime?         @map("actual_start_at") @db.Timestamptz(6)
  actualEndAt       DateTime?         @map("actual_end_at") @db.Timestamptz(6)
  blockingReason    String?           @map("blocking_reason")
  correlationId     String?           @map("correlation_id")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  version           Int               @default(0)

  workOrder   WoOrder        @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  assignments WoAssignment[]
  partLines   WoPartLine[]

  @@unique([workOrderId, sequenceNo])
  @@index([operationStatus])
  @@map("work_order_operations")
  @@schema("work_orders")
}

enum WoPartStatus {
  REQUESTED
  RESERVED
  PARTIALLY_CONSUMED
  CONSUMED
  SHORT
  CANCELLED

  @@schema("work_orders")
}

model WoPartLine {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId          String       @map("work_order_id") @db.Uuid
  workOrderOperationId String?      @map("work_order_operation_id") @db.Uuid
  partId               String       @map("part_id") @db.Uuid
  requestedQuantity    Decimal      @map("requested_quantity") @db.Decimal(14, 3)
  reservedQuantity     Decimal      @default(0) @map("reserved_quantity") @db.Decimal(14, 3)
  consumedQuantity     Decimal      @default(0) @map("consumed_quantity") @db.Decimal(14, 3)
  partStatus           WoPartStatus @default(REQUESTED) @map("part_status")
  shortageReason       String?      @map("shortage_reason")
  correlationId        String       @map("correlation_id")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  version              Int          @default(0)

  workOrder WoOrder      @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  operation WoOperation? @relation(fields: [workOrderOperationId], references: [id])
  part      Part         @relation(fields: [partId], references: [id])

  @@index([workOrderId])
  @@index([partId, partStatus])
  @@map("work_order_parts")
  @@schema("work_orders")
}

enum WoAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED

  @@schema("work_orders")
}

model WoAssignment {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId          String             @map("work_order_id") @db.Uuid
  workOrderOperationId String             @map("work_order_operation_id") @db.Uuid
  employeeId           String             @map("employee_id") @db.Uuid
  assignmentStatus     WoAssignmentStatus @default(ASSIGNED) @map("assignment_status")
  assignedStartAt      DateTime?          @map("assigned_start_at") @db.Timestamptz(6)
  assignedEndAt        DateTime?          @map("assigned_end_at") @db.Timestamptz(6)
  actualStartAt        DateTime?          @map("actual_start_at") @db.Timestamptz(6)
  actualEndAt          DateTime?          @map("actual_end_at") @db.Timestamptz(6)
  notes                String?
  correlationId        String             @map("correlation_id")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  version              Int                @default(0)

  operation WoOperation @relation(fields: [workOrderOperationId], references: [id], onDelete: Cascade)
  employee  Employee    @relation(fields: [employeeId], references: [id])

  @@index([employeeId, assignmentStatus])
  @@index([workOrderOperationId])
  @@map("work_order_assignments")
  @@schema("work_orders")
}

model WoStatusHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId   String   @map("work_order_id") @db.Uuid
  fromStatus    String?  @map("from_status")
  toStatus      String   @map("to_status")
  reasonCode    String?  @map("reason_code")
  reasonNote    String?  @map("reason_note")
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  correlationId String   @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workOrder WoOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, createdAt])
  @@map("work_order_status_history")
  @@schema("work_orders")
}

// ============================================================
// sop_ojt schema
// ============================================================

enum SopDocumentStatus {
  DRAFT
  PUBLISHED
  RETIRED

  @@schema("sop_ojt")
}

model SopDocument {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentCode     String            @map("document_code")
  title            String
  documentStatus   SopDocumentStatus @default(DRAFT) @map("document_status")
  category         String?
  ownerEmployeeId  String?           @map("owner_employee_id") @db.Uuid
  currentVersionId String?           @map("current_version_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  version          Int               @default(0)

  docVersions     SopDocumentVersion[]
  trainingModules TrainingModule[]

  @@map("sop_documents")
  @@schema("sop_ojt")
}

model SopDocumentVersion {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sopDocumentId   String    @map("sop_document_id") @db.Uuid
  versionNumber   Int       @map("version_number")
  contentMarkdown String    @map("content_markdown")
  contentHash     String    @map("content_hash")
  changeSummary   String?   @map("change_summary")
  effectiveAt     DateTime? @map("effective_at") @db.Timestamptz(6)
  correlationId   String    @map("correlation_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  sopDocument SopDocument @relation(fields: [sopDocumentId], references: [id], onDelete: Cascade)

  @@unique([sopDocumentId, versionNumber])
  @@map("sop_document_versions")
  @@schema("sop_ojt")
}

enum TrainingModuleStatus {
  ACTIVE
  INACTIVE
  RETIRED

  @@schema("sop_ojt")
}

model TrainingModule {
  id                        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleCode                String               @map("module_code")
  sopDocumentId             String?              @map("sop_document_id") @db.Uuid
  moduleName                String               @map("module_name")
  description               String?
  moduleStatus              TrainingModuleStatus @default(ACTIVE) @map("module_status")
  passScore                 Int?                 @map("pass_score")
  validityDays              Int?                 @map("validity_days")
  isRequired                Boolean              @default(true) @map("is_required")
  // OJT-specific content fields
  steps                     Json?                @default("[]")
  knowledgeChecks           Json?                @default("[]") @map("knowledge_checks")
  estimatedTime             String?              @map("estimated_time")
  prerequisites             String[]             @default([]) @map("prerequisites")
  jobRoles                  String[]             @default([]) @map("job_roles")
  requiresSupervisorSignoff Boolean              @default(false) @map("requires_supervisor_signoff")
  thumbnailUrl              String?              @map("thumbnail_url")
  sortOrder                 Int                  @default(0) @map("sort_order")
  createdAt                 DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt                 DateTime?            @map("deleted_at") @db.Timestamptz(6)
  version                   Int                  @default(0)

  sopDocument         SopDocument?         @relation(fields: [sopDocumentId], references: [id])
  trainingAssignments TrainingAssignment[]
  moduleProgress      ModuleProgress[]
  stepProgress        StepProgress[]
  quizAttempts        QuizAttempt[]
  ojtNotes            OjtNote[]
  ojtBookmarks        OjtBookmark[]
  ojtQuestions        OjtQuestion[]

  @@map("training_modules")
  @@schema("sop_ojt")
}

model ModuleProgress {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  moduleId    String    @map("module_id") @db.Uuid
  status      String    @default("not-started")
  currentStep String?   @map("current_step")
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  module TrainingModule @relation(fields: [moduleId], references: [id])

  @@unique([employeeId, moduleId])
  @@index([employeeId])
  @@map("module_progress")
  @@schema("sop_ojt")
}

model StepProgress {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  moduleId      String    @map("module_id") @db.Uuid
  stepId        String    @map("step_id")
  status        String    @default("not-started")
  videoWatched  Boolean   @default(false) @map("video_watched")
  videoProgress Decimal   @default(0) @map("video_progress") @db.Decimal(5, 2)
  completedAt   DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  module TrainingModule @relation(fields: [moduleId], references: [id])

  @@unique([employeeId, moduleId, stepId])
  @@index([employeeId])
  @@map("step_progress")
  @@schema("sop_ojt")
}

model QuizAttempt {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  moduleId       String   @map("module_id") @db.Uuid
  score          Int
  totalQuestions Int      @map("total_questions")
  passed         Boolean
  answers        Json     @default("[]")
  attemptedAt    DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)

  module TrainingModule @relation(fields: [moduleId], references: [id])

  @@index([employeeId])
  @@map("quiz_attempts")
  @@schema("sop_ojt")
}

model OjtNote {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  moduleId   String   @map("module_id") @db.Uuid
  stepId     String?  @map("step_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  module TrainingModule @relation(fields: [moduleId], references: [id])

  @@index([employeeId])
  @@map("ojt_notes")
  @@schema("sop_ojt")
}

model OjtBookmark {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  moduleId   String   @map("module_id") @db.Uuid
  stepId     String   @map("step_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  module TrainingModule @relation(fields: [moduleId], references: [id])

  @@unique([employeeId, moduleId, stepId])
  @@index([employeeId])
  @@map("ojt_bookmarks")
  @@schema("sop_ojt")
}

model OjtQuestion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  employeeName String   @default("") @map("employee_name")
  moduleId     String   @map("module_id") @db.Uuid
  stepId       String?  @map("step_id")
  question     String
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  module  TrainingModule @relation(fields: [moduleId], references: [id])
  answers OjtAnswer[]

  @@index([moduleId])
  @@index([status])
  @@map("ojt_questions")
  @@schema("sop_ojt")
}

model OjtAnswer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  adminId    String   @map("admin_id") @db.Uuid
  adminName  String   @default("") @map("admin_name")
  answer     String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  question OjtQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("ojt_answers")
  @@schema("sop_ojt")
}

enum TrainingAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  FAILED
  EXEMPT
  CANCELLED

  @@schema("sop_ojt")
}

model TrainingAssignment {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId         String                   @map("module_id") @db.Uuid
  employeeId       String                   @map("employee_id") @db.Uuid
  assignmentStatus TrainingAssignmentStatus @default(ASSIGNED) @map("assignment_status")
  dueAt            DateTime?                @map("due_at") @db.Timestamptz(6)
  startedAt        DateTime?                @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime?                @map("completed_at") @db.Timestamptz(6)
  score            Decimal?                 @db.Decimal(5, 2)
  correlationId    String                   @map("correlation_id")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  version          Int                      @default(0)

  module   TrainingModule @relation(fields: [moduleId], references: [id])
  employee Employee       @relation(fields: [employeeId], references: [id])

  @@index([employeeId, assignmentStatus])
  @@map("training_assignments")
  @@schema("sop_ojt")
}

model InspectionTemplate {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  smId          String    @unique @map("sm_id")
  name          String?
  category      String?
  isActive      Boolean   @default(true) @map("is_active")
  smCreatedDate DateTime? @map("sm_created_date") @db.Timestamptz(6)
  smUpdatedDate DateTime? @map("sm_updated_date") @db.Timestamptz(6)
  importedAt    DateTime  @default(now()) @map("imported_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  items InspectionTemplateItem[]

  @@map("inspection_templates")
  @@schema("sop_ojt")
}

model InspectionTemplateItem {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  smId                 String   @unique @map("sm_id")
  inspectionTemplateId String   @map("inspection_template_id") @db.Uuid
  name                 String?
  message              String?
  ordinal              BigInt   @default(0)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  template InspectionTemplate @relation(fields: [inspectionTemplateId], references: [id], onDelete: Cascade)

  @@index([inspectionTemplateId], map: "inspection_template_items_template_idx")
  @@map("inspection_template_items")
  @@schema("sop_ojt")
}

// ============================================================
// integrations schema
// ============================================================

enum IntegrationProvider {
  QUICKBOOKS
  SHOPMONKEY
  GENERIC

  @@schema("integrations")
}

enum IntegrationAccountStatus {
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED

  @@schema("integrations")
}

model IntegrationAccount {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider      IntegrationProvider
  accountKey    String                   @map("account_key")
  displayName   String                   @map("display_name")
  accountStatus IntegrationAccountStatus @default(ACTIVE) @map("account_status")
  configuration Json                     @default("{}") @db.JsonB
  lastSyncedAt  DateTime?                @map("last_synced_at") @db.Timestamptz(6)
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?                @map("deleted_at") @db.Timestamptz(6)
  version       Int                      @default(0)

  syncJobs           SyncJob[]
  externalIdMappings ExternalIdMapping[]
  webhookInboxEvents WebhookInboxEvent[]

  @@map("integration_accounts")
  @@schema("integrations")
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  CANCELLED

  @@schema("integrations")
}

model SyncJob {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integrationAccountId String        @map("integration_account_id") @db.Uuid
  jobType              String        @map("job_type")
  direction            String
  jobStatus            SyncJobStatus @default(QUEUED) @map("job_status")
  startedAt            DateTime?     @map("started_at") @db.Timestamptz(6)
  completedAt          DateTime?     @map("completed_at") @db.Timestamptz(6)
  attemptCount         Int           @default(0) @map("attempt_count")
  maxAttempts          Int           @default(5) @map("max_attempts")
  lastErrorCode        String?       @map("last_error_code")
  lastErrorMessage     String?       @map("last_error_message")
  correlationId        String        @map("correlation_id")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  version              Int           @default(0)

  integrationAccount IntegrationAccount @relation(fields: [integrationAccountId], references: [id])
  items              SyncJobItem[]

  @@index([integrationAccountId, jobStatus])
  @@map("sync_jobs")
  @@schema("integrations")
}

model SyncJobItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  syncJobId    String   @map("sync_job_id") @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  externalId   String?  @map("external_id")
  itemStatus   String   @default("PENDING") @map("item_status")
  attemptCount Int      @default(0) @map("attempt_count")
  errorCode    String?  @map("error_code")
  errorMessage String?  @map("error_message")
  payload      Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  version      Int      @default(0)

  syncJob SyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId, itemStatus])
  @@map("sync_job_items")
  @@schema("integrations")
}

model ExternalIdMapping {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integrationAccountId String   @map("integration_account_id") @db.Uuid
  entityType           String   @map("entity_type")
  entityId             String   @map("entity_id") @db.Uuid
  externalId           String   @map("external_id")
  namespace            String   @default("default")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  version              Int      @default(0)

  integrationAccount IntegrationAccount @relation(fields: [integrationAccountId], references: [id])

  @@unique([integrationAccountId, entityType, entityId, namespace])
  @@map("external_id_mappings")
  @@schema("integrations")
}

model WebhookInboxEvent {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integrationAccountId String    @map("integration_account_id") @db.Uuid
  providerEventId      String    @map("provider_event_id")
  eventType            String    @map("event_type")
  payload              Json      @db.JsonB
  processingStatus     String    @default("RECEIVED") @map("processing_status")
  attemptCount         Int       @default(0) @map("attempt_count")
  receivedAt           DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt          DateTime? @map("processed_at") @db.Timestamptz(6)
  lastError            String?   @map("last_error")
  correlationId        String    @map("correlation_id")
  version              Int       @default(0)

  integrationAccount IntegrationAccount @relation(fields: [integrationAccountId], references: [id])

  @@unique([integrationAccountId, providerEventId])
  @@index([processingStatus, receivedAt])
  @@map("webhook_inbox_events")
  @@schema("integrations")
}

// ============================================================
// customers schema
// ============================================================

enum CustomerLifecycleState {
  LEAD
  ACTIVE
  INACTIVE
  ARCHIVED

  @@schema("customers")
}

model Customer {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  state                  CustomerLifecycleState @default(LEAD)
  externalReference      String?                @map("external_reference")
  fullName               String                 @map("full_name")
  companyName            String?                @map("company_name")
  email                  String
  phone                  String?
  billingAddress         String?                @map("billing_address")
  shippingAddress        String?                @map("shipping_address")
  preferredContactMethod String                 @default("EMAIL") @map("preferred_contact_method")
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  archivedAt             DateTime?              @map("archived_at") @db.Timestamptz(6)
  version                Int                    @default(0)

  @@index([state])
  @@map("customers")
  @@schema("customers")
}

// ============================================================
// tickets schema
// ============================================================

enum TechnicianTaskState {
  READY
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED

  @@schema("tickets")
}

model TechnicianTask {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId   String              @map("work_order_id") @db.Uuid
  routingStepId String              @map("routing_step_id")
  technicianId  String?             @map("technician_id") @db.Uuid
  state         TechnicianTaskState @default(READY)
  startedAt     DateTime?           @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime?           @map("completed_at") @db.Timestamptz(6)
  blockedReason String?             @map("blocked_reason")
  correlationId String              @map("correlation_id")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  version       Int                 @default(0)

  laborTimeEntries LaborTimeEntry[]

  @@index([workOrderId, state])
  @@index([technicianId, state])
  @@map("technician_tasks")
  @@schema("tickets")
}

enum ReworkIssueState {
  OPEN
  IN_REVIEW
  RESOLVED
  REOPENED
  CLOSED

  @@schema("tickets")
}

model ReworkIssue {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId   String           @map("work_order_id") @db.Uuid
  title         String
  description   String
  severity      String           @default("MEDIUM")
  state         ReworkIssueState @default(OPEN)
  reportedBy    String           @map("reported_by") @db.Uuid
  assignedTo    String?          @map("assigned_to") @db.Uuid
  resolvedAt    DateTime?        @map("resolved_at") @db.Timestamptz(6)
  correlationId String           @map("correlation_id")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  version       Int              @default(0)

  @@index([workOrderId, state])
  @@map("rework_issues")
  @@schema("tickets")
}

model FileAttachment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id") @db.Uuid
  fileName      String    @map("file_name")
  mimeType      String    @map("mime_type")
  sizeBytes     Int       @map("size_bytes")
  s3Key         String    @map("s3_key")
  s3Bucket      String    @map("s3_bucket")
  uploadedBy    String    @map("uploaded_by") @db.Uuid
  correlationId String    @map("correlation_id")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  version       Int       @default(0)

  stepEvidenceAttachments StepEvidenceAttachment[]

  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@map("file_attachments")
  @@schema("tickets")
}

// ============================================================
// accounting schema
// ============================================================

enum InvoiceSyncState {
  PENDING
  IN_PROGRESS
  SYNCED
  FAILED
  CANCELLED

  @@schema("accounting")
}

model InvoiceSyncRecord {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber     String           @map("invoice_number")
  workOrderId       String           @map("work_order_id") @db.Uuid
  provider          String           @default("QUICKBOOKS")
  state             InvoiceSyncState @default(PENDING)
  attemptCount      Int              @default(0) @map("attempt_count")
  lastErrorCode     String?          @map("last_error_code")
  lastErrorMessage  String?          @map("last_error_message")
  externalReference String?          @map("external_reference")
  syncedAt          DateTime?        @map("synced_at") @db.Timestamptz(6)
  correlationId     String           @map("correlation_id")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  version           Int              @default(0)

  @@index([workOrderId])
  @@index([state])
  @@map("invoice_sync_records")
  @@schema("accounting")
}

enum CustomerSyncState {
  PENDING
  IN_PROGRESS
  SYNCED
  FAILED
  SKIPPED

  @@schema("accounting")
}

model CustomerSyncRecord {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId        String            @map("customer_id") @db.Uuid
  provider          String            @default("QUICKBOOKS")
  state             CustomerSyncState @default(PENDING)
  attemptCount      Int               @default(0) @map("attempt_count")
  lastErrorCode     String?           @map("last_error_code")
  lastErrorMessage  String?           @map("last_error_message")
  externalReference String?           @map("external_reference")
  syncedAt          DateTime?         @map("synced_at") @db.Timestamptz(6)
  correlationId     String            @map("correlation_id")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  version           Int               @default(0)

  @@unique([customerId, provider])
  @@index([state])
  @@map("customer_sync_records")
  @@schema("accounting")
}

// ============================================================
// integrations schema — payment sync & reconciliation
// ============================================================

enum PaymentSyncState {
  PENDING
  IN_PROGRESS
  SYNCED
  FAILED
  RECONCILED
  MISMATCH

  @@schema("integrations")
}

enum SyncDirection {
  INBOUND
  OUTBOUND

  @@schema("integrations")
}

enum ReconciliationStatus {
  PENDING
  MATCHED
  MISMATCH
  RESOLVED
  SKIPPED

  @@schema("integrations")
}

model PaymentSyncRecord {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceSyncId String?          @map("invoice_sync_id") @db.Uuid
  workOrderId   String           @map("work_order_id") @db.Uuid
  customerId    String           @map("customer_id") @db.Uuid
  qbPaymentId   String?          @map("qb_payment_id")
  qbInvoiceId   String?          @map("qb_invoice_id")
  amountCents   Int              @map("amount_cents")
  paymentMethod String?          @map("payment_method")
  paymentDate   DateTime?        @map("payment_date") @db.Date
  state         PaymentSyncState @default(PENDING) @map("state")
  direction     SyncDirection    @default(INBOUND) @map("direction")
  errorMessage  String?          @map("error_message")
  attemptCount  Int              @default(0) @map("attempt_count")
  lastAttemptAt DateTime?        @map("last_attempt_at") @db.Timestamptz(6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([workOrderId])
  @@index([state])
  @@index([qbPaymentId])
  @@map("payment_sync_records")
  @@schema("integrations")
}

model ReconciliationRun {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime? @map("completed_at") @db.Timestamptz(6)
  status        String    @default("RUNNING") @map("status")
  totalRecords  Int       @default(0) @map("total_records")
  matchedCount  Int       @default(0) @map("matched_count")
  mismatchCount Int       @default(0) @map("mismatch_count")
  errorCount    Int       @default(0) @map("error_count")
  triggeredBy   String?   @map("triggered_by")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("reconciliation_runs")
  @@schema("integrations")
}

model ReconciliationRecord {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reconciliationType String               @map("reconciliation_type")
  erpRecordId        String               @map("erp_record_id")
  qbRecordId         String?              @map("qb_record_id")
  status             ReconciliationStatus @default(PENDING) @map("status")
  erpAmountCents     Int?                 @map("erp_amount_cents")
  qbAmountCents      Int?                 @map("qb_amount_cents")
  discrepancy        String?              @map("discrepancy")
  resolvedAt         DateTime?            @map("resolved_at") @db.Timestamptz(6)
  resolvedBy         String?              @map("resolved_by")
  notes              String?
  runId              String               @map("run_id") @db.Uuid
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([runId])
  @@index([status])
  @@index([reconciliationType, erpRecordId])
  @@map("reconciliation_records")
  @@schema("integrations")
}

// ============================================================
// planning schema — technician floor additions
// ============================================================

model RoutingSopStep {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId      String    @map("work_order_id") @db.Uuid
  stepCode         String    @map("step_code")
  stepName         String    @map("step_name")
  sequenceNo       Int       @map("sequence_no")
  description      String?
  estimatedMinutes Int?      @map("estimated_minutes")
  executionState   String    @default("PENDING") @map("execution_state")
  completedBy      String?   @map("completed_by")
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)
  failedReason     String?   @map("failed_reason")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  stepEvidenceAttachments StepEvidenceAttachment[]

  @@index([workOrderId])
  @@map("routing_sop_steps")
  @@schema("planning")
}

// ============================================================
// tickets schema — technician floor additions
// ============================================================

model StepEvidenceAttachment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routingStepId    String   @map("routing_step_id") @db.Uuid
  fileAttachmentId String   @map("file_attachment_id") @db.Uuid
  uploadedBy       String   @map("uploaded_by")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  routingStep    RoutingSopStep @relation(fields: [routingStepId], references: [id], onDelete: Cascade)
  fileAttachment FileAttachment @relation(fields: [fileAttachmentId], references: [id], onDelete: Cascade)

  @@index([routingStepId], map: "step_evidence_routing_step_idx")
  @@map("step_evidence_attachments")
  @@schema("tickets")
}

model LaborTimeEntry {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  technicianTaskId String?   @map("technician_task_id") @db.Uuid
  workOrderId      String    @map("work_order_id") @db.Uuid
  technicianId     String    @map("technician_id")
  startedAt        DateTime  @map("started_at") @db.Timestamptz(6)
  endedAt          DateTime? @map("ended_at") @db.Timestamptz(6)
  manualHours      Decimal?  @map("manual_hours") @db.Decimal(6, 2)
  description      String?
  source           String    @default("MANUAL") @map("source")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  technicianTask TechnicianTask? @relation(fields: [technicianTaskId], references: [id])

  @@index([workOrderId, technicianId], map: "labor_entries_wo_tech_idx")
  @@index([technicianTaskId], map: "labor_entries_task_idx")
  @@map("labor_time_entries")
  @@schema("tickets")
}

// ============================================================
// work_orders schema — technician floor additions
// ============================================================

model WorkOrderQcGate {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId String    @map("work_order_id") @db.Uuid
  taskId      String?   @map("task_id") @db.Uuid
  gateLabel   String    @map("gate_label")
  isCritical  Boolean   @default(false) @map("is_critical")
  result      String?
  failureNote String?   @map("failure_note")
  reviewedBy  String?   @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workOrder WoOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId], map: "qc_gates_work_order_idx")
  @@index([taskId], map: "qc_gates_task_idx")
  @@map("work_order_qc_gates")
  @@schema("work_orders")
}
